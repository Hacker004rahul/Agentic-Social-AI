MONGO_URI=mongodb://localhost:27017
DB_NAME=agentic_social_ai
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── OAuth App Credentials (set these in your .env) ─────────
# These are YOUR developer app credentials, not the user's.
# Users never see these — they just click "Connect with ..."

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X (Twitter)
X_CLIENT_ID=
X_CLIENT_SECRET=

# Facebook & Instagram (same Meta app)
META_CLIENT_ID=
META_CLIENT_SECRET=

# YouTube (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Buffer
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=

# Must match what you set in each developer portal
OAUTH_REDIRECT_BASE=http://localhost:8000

